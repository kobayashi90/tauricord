{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "local": true,
  "remote": {
    "urls": [
      "https://discord.com/*",
      "https://*.discord.com/*"
    ]
  },
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    "fs:allow-read",
    "fs:scope"
  ]
}
